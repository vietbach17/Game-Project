# This .gitignore file is automatically generated for Unity projects.
# It ensures that temporary files, logs, and build artifacts are not tracked.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory Captures and Recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Visual Studio / Rider / VS Code cache and autogenerated files
.vs/
.idea/
.vscode/
/*.sln
/*.csproj
/*.unityproj
/*.suo
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.bak
/*.slnx

# OS generated files
.DS_Store
Thumbs.db
